@page "/profile"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits AppPageBase

@if (HasError)
{
    <ErrorDisplay Message="@ErrorMessage"
                  ReferenceNumber="@ErrorReferenceNumber"
                  TechnicalDetails="@ErrorTechnicalDetails"
                  ShowTechnicalDetails="true"
                  OnRetry="LoadAsync" />
}
else
{
    <section class="profile-page">
        <header class="profile-page__hero">
            <div class="profile-page__hero-copy">
                <div class="profile-page__meta">
                    <span class="profile-page__role-chip">@_role</span>
                    <small>عضو منذ @_profile.CreatedAt.ToLocalTime().ToString("MMMM yyyy")</small>
                </div>

                <h1>@_profile.FullName</h1>
                <p>@_profile.Email</p>
            </div>

            <div class="profile-page__hero-actions">
                <button type="button" class="profile-page__ghost-action" @onclick="LoadAsync">إلغاء</button>
                <button type="button" class="profile-page__primary-action" @onclick="SaveAsync" disabled="@_isSaving">
                    @(_isSaving ? "جاري الحفظ..." : "حفظ التغييرات")
                </button>
            </div>

            <div class="profile-page__avatar-shell">
                <div class="profile-page__avatar">@_initials</div>
                <button type="button" aria-label="تعديل الصورة">
                    <span class="material-symbols-outlined">edit</span>
                </button>
            </div>
        </header>

        <div class="profile-page__grid">
            <aside class="profile-page__rail">
                <article class="profile-page__insight-card">
                    <p>إحصائيات النشاط</p>
                    <strong>128</strong>
                    <span>تقرير تم إنشاؤه خلال الفترة الأخيرة</span>
                    <div class="profile-page__progress">
                        <i></i>
                    </div>
                    <small>تم إنجاز 75% من الأهداف التشغيلية الحالية.</small>
                </article>

                <article class="profile-page__sessions-card">
                    <h2>جلسات تسجيل الدخول</h2>
                    <div>
                        <strong>MacBook Pro</strong>
                        <small>نشط الآن</small>
                    </div>
                    <div>
                        <strong>iPhone 15</strong>
                        <small>منذ ساعتين</small>
                    </div>
                </article>
            </aside>

            <div class="profile-page__content">
                <article class="profile-page__panel">
                    <header>
                        <h2>المعلومات الشخصية</h2>
                        <span class="material-symbols-outlined">person</span>
                    </header>

                    <EditForm Model="_request" class="profile-page__form" OnValidSubmit="SaveAsync">
                        <DataAnnotationsValidator />
                        <ValidationSummary />

                        <FormField TValue="string" Label="الاسم الكامل" For="() => _request.FullName">
                            <FormInput @bind-Value="_request.FullName" placeholder="اكتب الاسم الكامل" />
                        </FormField>

                        <div class="profile-page__readonly-grid">
                            <div>
                                <label>المسمى الوظيفي</label>
                                <div>@(_role == "SuperAdmin" ? "مدير النظام الرئيسي" : _role == "Admin" ? "إداري تشغيلي" : "مستخدم")</div>
                            </div>

                            <div class="profile-page__readonly profile-page__readonly--locked">
                                <label>البريد الإلكتروني</label>
                                <div>
                                    <span>@_profile.Email</span>
                                    <span class="material-symbols-outlined">lock</span>
                                </div>
                            </div>
                        </div>
                    </EditForm>
                </article>

                <article class="profile-page__panel">
                    <header>
                        <h2>الأمان والوصول</h2>
                        <span class="material-symbols-outlined">security</span>
                    </header>

                    <div class="profile-page__security-item">
                        <div>
                            <strong>المصادقة الثنائية</strong>
                            <p>مفعلة منذ 4 أشهر</p>
                        </div>
                        <button type="button" @onclick="@(() => ToastService.ShowInfo("إدارة 2FA ستتضاف لاحقًا."))">إدارة</button>
                    </div>
                </article>
            </div>
        </div>
    </section>
}

@code {
    private UserDto _profile = new() { FullName = "User", Email = "user@zerodawn.local", Roles = ["User"], CreatedAt = DateTime.UtcNow.AddMonths(-1) };
    private UpdateProfileRequest _request = new();
    private bool _isSaving;
    private string _role = "User";
    private string _initials = "U";

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        ClearError();

        try
        {
            if (UserApiClient is not null)
            {
                var response = await UserApiClient.GetProfileAsync();
                if (!response.Succeeded || response.Data is null)
                {
                    SetApiError(response);
                    ShowApiErrors(response);
                    return;
                }

                _profile = response.Data;
            }
            else
            {
                var user = await GetCurrentUserAsync();
                _profile = new UserDto
                {
                    Id = "self",
                    FullName = GetDisplayName(user),
                    Email = user.FindFirst(ClaimTypes.Email)?.Value ?? "user@zerodawn.local",
                    Roles = [GetRole(user) ?? "User"],
                    CreatedAt = DateTime.UtcNow.AddMonths(-3),
                    EmailConfirmed = true
                };
            }

            _request = new UpdateProfileRequest { FullName = _profile.FullName };
            _role = _profile.Roles.FirstOrDefault() ?? "User";
            _initials = GetInitials(_profile.FullName);
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
    }

    private async Task SaveAsync()
    {
        if (_isSaving)
        {
            return;
        }

        _isSaving = true;
        ClearError();

        try
        {
            if (UserApiClient is not null)
            {
                var response = await UserApiClient.UpdateProfileAsync(_request);
                if (!response.Succeeded || response.Data is null)
                {
                    ShowApiErrors(response);
                    return;
                }

                _profile = response.Data;
            }
            else
            {
                _profile = new UserDto
                {
                    Id = _profile.Id,
                    FullName = _request.FullName,
                    Email = _profile.Email,
                    Roles = _profile.Roles,
                    IsActive = _profile.IsActive,
                    CreatedAt = _profile.CreatedAt,
                    LastLoginAt = _profile.LastLoginAt,
                    EmailConfirmed = _profile.EmailConfirmed
                };
            }

            _initials = GetInitials(_profile.FullName);
            ShowSuccess("تم تحديث الملف الشخصي.");
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isSaving = false;
        }
    }
}
