@page "/not-found"
@layout MainLayout
@inherits AppPageBase

<div class="card text-center">
    <div aria-hidden="true" style="display:flex;justify-content:center;margin-bottom:1rem;">
        <svg width="180" height="120" viewBox="0 0 180 120" fill="none" xmlns="http://www.w3.org/2000/svg">
            <rect x="12" y="18" width="156" height="84" rx="20" fill="var(--color-surface)" stroke="var(--color-border)" stroke-width="2" />
            <circle cx="64" cy="56" r="8" fill="var(--color-text-muted)" />
            <circle cx="116" cy="56" r="8" fill="var(--color-text-muted)" />
            <path d="M64 82C72 72 108 72 116 82" stroke="var(--color-error)" stroke-width="4" stroke-linecap="round" />
            <path d="M32 34L48 50" stroke="var(--color-warning)" stroke-width="4" stroke-linecap="round" />
            <path d="M48 34L32 50" stroke="var(--color-warning)" stroke-width="4" stroke-linecap="round" />
            <path d="M132 34L148 50" stroke="var(--color-warning)" stroke-width="4" stroke-linecap="round" />
            <path d="M148 34L132 50" stroke="var(--color-warning)" stroke-width="4" stroke-linecap="round" />
        </svg>
    </div>
    <h1 class="mt-3 mb-2">404</h1>
    <p class="text-muted mb-3">@L["NotFound"]</p>
    <a class="btn btn-primary mx-auto" href="/">@L["Home"]</a>
</div>
