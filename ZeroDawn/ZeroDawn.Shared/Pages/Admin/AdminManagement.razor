@page "/admin/admins"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@inherits AppPageBase

@if (HasError)
{
    <ErrorDisplay Message="@ErrorMessage"
                  ReferenceNumber="@ErrorReferenceNumber"
                  TechnicalDetails="@ErrorTechnicalDetails"
                  ShowTechnicalDetails="true"
                  OnRetry="LoadAsync" />
}
else
{
    <section class="admin-management">
        <header class="admin-management__hero">
            <div>
                <p class="admin-management__eyebrow">حوكمة الصلاحيات</p>
                <h1>إدارة المدراء</h1>
                <p class="admin-management__subtitle">
                    متابعة صلاحيات الـ SuperAdmin و Admin بطريقة هادئة وواضحة، مع سطح تشغيلي يوضح
                    الحالة الحالية والحركات الحساسة بسرعة.
                </p>
            </div>

            <div class="admin-management__hero-actions">
                <button type="button" class="admin-management__secondary-action">
                    <span class="material-symbols-outlined">filter_list</span>
                    تصفية
                </button>
                <button type="button" class="admin-management__primary-action">
                    <span class="material-symbols-outlined">person_add</span>
                    تعيين مدير جديد
                </button>
            </div>
        </header>

        <section class="admin-management__stats">
            <article class="admin-management__stat-card">
                <span>إجمالي المدراء</span>
                <strong>@_admins.Count</strong>
                <small>إجمالي الحسابات ذات الصلاحيات الإدارية</small>
            </article>
            <article class="admin-management__stat-card">
                <span>الجلسات النشطة</span>
                <strong>@_admins.Count(admin => admin.LastLoginAt is not null && admin.LastLoginAt > DateTime.UtcNow.AddHours(-8))</strong>
                <small>حركة آخر 8 ساعات</small>
            </article>
            <article class="admin-management__stat-card admin-management__stat-card--wide">
                <div>
                    <span>سلامة الصلاحيات</span>
                    <strong>@($"{ComputeSecurityHealth():0.#}%")</strong>
                </div>
                <div class="admin-management__health-bars" aria-hidden="true">
                    @for (var i = 0; i < 4; i++)
                    {
                        <span class="@(i < 3 ? "is-active" : string.Empty)"></span>
                    }
                </div>
                <small>مبني على نسبة الحسابات النشطة والمؤكدة البريد</small>
            </article>
        </section>

        <section class="admin-management__table-shell">
            <header class="admin-management__table-header">
                <div>
                    <h2>المدراء الحاليون</h2>
                    <div class="admin-management__table-tags">
                        <span>SuperAdmin: @_admins.Count(admin => admin.Roles.Contains("SuperAdmin"))</span>
                        <span>Admin: @_admins.Count(admin => admin.Roles.Contains("Admin"))</span>
                    </div>
                </div>

                <div class="admin-management__table-tools">
                    <button type="button" aria-label="طباعة">
                        <span class="material-symbols-outlined">print</span>
                    </button>
                    <button type="button" aria-label="تصدير">
                        <span class="material-symbols-outlined">download</span>
                    </button>
                </div>
            </header>

            @if (_isLoading)
            {
                <div class="admin-management__loading">
                    <Skeleton Height="4.5rem" />
                    <Skeleton Height="4.5rem" />
                    <Skeleton Height="4.5rem" />
                </div>
            }
            else if (_admins.Count == 0)
            {
                <EmptyState Message="لا يوجد مدراء لعرضهم حاليًا." />
            }
            else
            {
                <div class="admin-management__table-wrap">
                    <table class="admin-management__table">
                        <thead>
                            <tr>
                                <th>المستخدم</th>
                                <th>الدور</th>
                                <th>الحالة</th>
                                <th>آخر دخول</th>
                                <th>الإجراء</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var admin in _admins)
                            {
                                var isSuperAdmin = admin.Roles.Contains("SuperAdmin");
                                var roleLabel = isSuperAdmin ? "SuperAdmin" : admin.Roles.FirstOrDefault() ?? "Admin";
                                <tr>
                                    <td>
                                        <div class="admin-management__identity">
                                            <div class="admin-management__avatar">@GetInitials(admin.FullName)</div>
                                            <div>
                                                <strong>@admin.FullName</strong>
                                                <small>@admin.Email</small>
                                            </div>
                                        </div>
                                    </td>
                                    <td>
                                        <span class="admin-management__role @(isSuperAdmin ? "is-critical" : "is-standard")">@roleLabel</span>
                                    </td>
                                    <td>
                                        <span class="admin-management__status @(admin.IsActive ? "is-active" : "is-inactive")">
                                            @if (admin.IsActive)
                                            {
                                                <span class="material-symbols-outlined">check_circle</span>
                                                <span>نشط</span>
                                            }
                                            else
                                            {
                                                <span class="material-symbols-outlined">do_not_disturb_on</span>
                                                <span>موقوف</span>
                                            }
                                        </span>
                                    </td>
                                    <td>
                                        <div class="admin-management__last-login">
                                            @if (admin.LastLoginAt is { } lastLogin)
                                            {
                                                <strong>@lastLogin.ToLocalTime().ToString("g")</strong>
                                            }
                                            else
                                            {
                                                <strong>لا يوجد</strong>
                                            }
                                        </div>
                                    </td>
                                    <td>
                                        <button type="button" class="admin-management__row-action" @onclick="() => ToggleAdminAsync(admin)">
                                            <span class="material-symbols-outlined">admin_panel_settings</span>
                                            @(admin.Roles.Contains("Admin") ? "إرجاع لمستخدم" : "ترقية لمدير")
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>

        <section class="admin-management__lower-grid">
            <article class="admin-management__audit-card">
                <p>مراجعة صلاحيات معلقة</p>
                <strong>@Math.Max(1, _admins.Count / 2) حساب</strong>
                <span>الحسابات غير النشطة أو منخفضة الاستخدام تستحق مراجعة ربع سنوية.</span>
                <button type="button">بدء المراجعة</button>
            </article>

            <article class="admin-management__events-card">
                <header>
                    <h3>آخر الحركات الحساسة</h3>
                    <a href="/admin/error-logs">عرض السجل</a>
                </header>

                <div class="admin-management__events-list">
                    @foreach (var admin in _admins.Take(3))
                    {
                        <div class="admin-management__event-item">
                            <div>
                                <strong>تعديل صلاحيات: @admin.FullName</strong>
                                <p>
                                    @(admin.Roles.Contains("SuperAdmin")
                                        ? "يملك أعلى صلاحيات في النظام ويحتاج متابعة دقيقة."
                                        : "حساب إداري تشغيلي مع صلاحيات على إدارة المستخدمين والمتابعة.")
                                </p>
                            </div>
                            <span>@((admin.LastLoginAt ?? admin.CreatedAt).ToLocalTime().ToString("g"))</span>
                        </div>
                    }
                </div>
            </article>
        </section>
    </section>
}

@code {
    private List<UserDto> _admins = [];
    private bool _isLoading = true;

    protected override Task OnInitializedAsync() => LoadAsync();

    private async Task LoadAsync()
    {
        ClearError();
        _isLoading = true;

        try
        {
            if (AdminApiClient is not null)
            {
                var response = await AdminApiClient.GetAdminsAsync();
                if (!response.Succeeded || response.Data is null)
                {
                    SetApiError(response);
                    ShowApiErrors(response);
                    _admins = [];
                    return;
                }

                _admins = response.Data;
            }
            else
            {
                _admins =
                [
                    new() { Id = "1", FullName = "لواء الأشقر", Email = "loai.asp97@gmail.com", Roles = ["SuperAdmin"], IsActive = true, CreatedAt = DateTime.UtcNow.AddMonths(-8), EmailConfirmed = true, LastLoginAt = DateTime.UtcNow.AddMinutes(-32) },
                    new() { Id = "2", FullName = "سارة الفايد", Email = "sarah.admin@zerodawn.local", Roles = ["Admin", "User"], IsActive = true, CreatedAt = DateTime.UtcNow.AddMonths(-6), EmailConfirmed = true, LastLoginAt = DateTime.UtcNow.AddHours(-2) },
                    new() { Id = "3", FullName = "ليو سترلينج", Email = "leo.ops@zerodawn.local", Roles = ["Admin"], IsActive = false, CreatedAt = DateTime.UtcNow.AddMonths(-4), EmailConfirmed = true, LastLoginAt = DateTime.UtcNow.AddDays(-1) }
                ];
            }
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task ToggleAdminAsync(UserDto admin)
    {
        var nextRole = admin.Roles.Contains("Admin") ? "User" : "Admin";

        try
        {
            if (AdminApiClient is not null)
            {
                var response = await AdminApiClient.UpdateAdminRoleAsync(admin.Id, new AssignRoleRequest
                {
                    UserId = admin.Id,
                    Role = nextRole
                });

                if (!response.Succeeded || response.Data is null)
                {
                    ShowApiErrors(response);
                    return;
                }

                ReplaceAdmin(response.Data);
            }
            else
            {
                ReplaceAdmin(new UserDto
                {
                    Id = admin.Id,
                    FullName = admin.FullName,
                    Email = admin.Email,
                    Roles = nextRole == "Admin" ? ["Admin", "User"] : ["User"],
                    IsActive = admin.IsActive,
                    CreatedAt = admin.CreatedAt,
                    LastLoginAt = admin.LastLoginAt,
                    EmailConfirmed = admin.EmailConfirmed
                });
            }

            ShowSuccess("تم تحديث دور المدير بنجاح.");
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
    }

    private void ReplaceAdmin(UserDto updatedAdmin)
    {
        var index = _admins.FindIndex(admin => admin.Id == updatedAdmin.Id);
        if (index >= 0)
        {
            _admins[index] = updatedAdmin;
        }
    }

    private double ComputeSecurityHealth()
    {
        if (_admins.Count == 0)
        {
            return 100;
        }

        var secureCount = _admins.Count(admin => admin.IsActive && admin.EmailConfirmed);
        return secureCount * 100d / _admins.Count;
    }
}
