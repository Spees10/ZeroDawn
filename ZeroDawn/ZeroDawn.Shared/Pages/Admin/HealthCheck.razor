@page "/admin/health"
@layout MainLayout
@inherits AppPageBase
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@using System.Net.Http.Json
@using Microsoft.Extensions.DependencyInjection

@if (HasError)
{
    <ErrorDisplay Message="@ErrorMessage"
                  ReferenceNumber="@ErrorReferenceNumber"
                  TechnicalDetails="@ErrorTechnicalDetails"
                  ShowTechnicalDetails="true"
                  OnRetry="LoadAsync" />
}
else if (_isLoading)
{
    <section class="health-diagnostics__loading">
        <LoadingSpinner Size="large" />
        <p>@L["Loading"]</p>
    </section>
}
else if (_report is null)
{
    <EmptyState Message="تعذر تحميل الحالة الصحية للنظام." />
}
else
{
    <section class="health-diagnostics">
        <header class="health-diagnostics__hero">
            <div>
                <p class="health-diagnostics__eyebrow">System intelligence</p>
                <h1>تشخيص الحالة الصحية</h1>
                <p>
                    متابعة مباشرة للبنية التحتية والخدمات الأساسية مع إبراز المكونات المتدهورة أو البطيئة
                    من غير ضوضاء بصرية.
                </p>
            </div>

            <div class="health-diagnostics__hero-actions">
                <button type="button" class="health-diagnostics__ghost-action">تصدير</button>
                <button type="button" class="health-diagnostics__primary-action" @onclick="LoadAsync" disabled="@_isLoading">
                    <span class="material-symbols-outlined">refresh</span>
                    إعادة فحص
                </button>
            </div>
        </header>

        <section class="health-diagnostics__overview">
            <article class="health-diagnostics__metric-card">
                <span>مؤشر التهديد</span>
                <strong>@ResolveThreatIndex()</strong>
                <small>حسب الحالات غير الصحية الحالية</small>
            </article>
            <article class="health-diagnostics__metric-card">
                <span>سعة الحمل</span>
                <strong>@($"{ComputeLoadHeadroom():0.#}%")</strong>
                <small>هامش متبقي قبل التشبع</small>
            </article>
            <article class="health-diagnostics__metric-card">
                <span>متوسط التأخير</span>
                <strong>@($"{AverageDuration():0}")<small>ms</small></strong>
                <small>متوسط مدد الفحوصات الحالية</small>
            </article>
            <article class="health-diagnostics__protocol-card @MapProtocolClass(_report.Status)">
                <div>
                    <span>الحالة الحالية</span>
                    <h2>@ResolveStatusArabic(_report.Status)</h2>
                </div>
                <div class="health-diagnostics__protocol-meta">
                    <strong>@($"{ProtocolPercent():0.###}%")</strong>
                    <small>استقرار التشغيـل</small>
                </div>
            </article>
        </section>

        <section class="health-diagnostics__checks-shell">
            <header>
                <div class="health-diagnostics__legend">
                    <span><i class="is-critical"></i> حرج</span>
                    <span><i class="is-active"></i> نشط</span>
                </div>
                <h3>مكونات التشخيص</h3>
            </header>

            <div class="health-diagnostics__checks">
                @foreach (var check in _report.Checks)
                {
                    <article class="health-diagnostics__check-row">
                        <button type="button" aria-label="تفاصيل">
                            <span class="material-symbols-outlined">chevron_left</span>
                        </button>
                        <span class="health-diagnostics__badge @MapBadgeClass(check.Status)">@ResolveStatusArabic(check.Status)</span>
                        <div class="health-diagnostics__duration">
                            <small>Duration</small>
                            <strong>@($"{check.Duration:0.##}ms")</strong>
                        </div>
                        <div class="health-diagnostics__copy">
                            <strong>@check.Name</strong>
                            <p>@(string.IsNullOrWhiteSpace(check.Description) ? "فحص داخلي بدون وصف إضافي." : check.Description)</p>
                        </div>
                        <div class="health-diagnostics__icon">
                            <span class="material-symbols-outlined">@ResolveCheckIcon(check.Name)</span>
                        </div>
                    </article>
                }
            </div>
        </section>

        <section class="health-diagnostics__lower-grid">
            <article class="health-diagnostics__hardware-card">
                <h3>سلامة العتاد</h3>
                <div class="health-diagnostics__hardware-metrics">
                    <div>
                        <span>استهلاك الطاقة</span>
                        <strong>@($"{ComputePowerConsumption():0.0}kW")</strong>
                    </div>
                    <div>
                        <span>حرارة الذاكرة</span>
                        <strong>@($"{ComputeMemoryThermal():0}°C")</strong>
                    </div>
                </div>
                <p>العُقد الحالية تعمل ضمن الحدود الطبيعية بدون اختناقات ملحوظة.</p>
            </article>

            <article class="health-diagnostics__console-card">
                <header>
                    <h3>RAM output logs</h3>
                    <span>SYSTEM_ID [4.1.0]</span>
                </header>
                <div class="health-diagnostics__console-lines">
                    @foreach (var line in BuildConsoleLines())
                    {
                        <div>
                            <span>@line.Time</span>
                            <p>@line.Text</p>
                            <strong class="@line.Class">@line.Level</strong>
                        </div>
                    }
                </div>
            </article>
        </section>
    </section>
}

@code {
    private HealthReportViewModel? _report;
    private bool _isLoading = true;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return Task.CompletedTask;
        }

        return LoadAsync();
    }

    private async Task LoadAsync()
    {
        ClearError();
        _isLoading = true;
        _report = null;
        StateHasChanged();

        try
        {
            var factoryType = Type.GetType("System.Net.Http.IHttpClientFactory, Microsoft.Extensions.Http")
                ?? throw new InvalidOperationException("IHttpClientFactory type is unavailable.");
            var factory = Services.GetService(factoryType)
                ?? throw new InvalidOperationException("IHttpClientFactory is not registered.");
            var createClientMethod = factoryType.GetMethod("CreateClient", [typeof(string)])
                ?? throw new InvalidOperationException("CreateClient method was not found.");
            using var client = (HttpClient?)createClientMethod.Invoke(factory, ["ApiAuthenticated"])
                ?? throw new InvalidOperationException("Authenticated HttpClient could not be created.");
            var result = await client.GetFromJsonAsync<HealthReportViewModel>("api/health");

            if (result is null)
            {
                throw new InvalidOperationException("Health check response was empty.");
            }

            _report = result;
        }
        catch (Exception ex)
        {
            SetError(ex);
            ToastService.ShowError(L["ErrorOccurred"]);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private string ResolveThreatIndex()
    {
        if (_report is null)
        {
            return "منخفض";
        }

        return _report.Checks.Any(check => check.Status == "Unhealthy")
            ? "مرتفع"
            : _report.Checks.Any(check => check.Status == "Degraded")
                ? "متوسط"
                : "منخفض";
    }

    private double ComputeLoadHeadroom()
        => _report is null ? 100 : Math.Max(12.4, 100 - _report.Checks.Count * 7.8);

    private double AverageDuration()
        => _report?.Checks.Count > 0 ? _report.Checks.Average(check => check.Duration) : 24;

    private double ProtocolPercent()
        => _report?.Status == "Healthy" ? 99.982 : _report?.Status == "Degraded" ? 87.1 : 62.4;

    private double ComputePowerConsumption()
        => 1.2 + ((_report?.Checks.Count(check => check.Status == "Healthy") ?? 0) * 0.08);

    private double ComputeMemoryThermal()
        => 34 + ((_report?.Checks.Count(check => check.Status != "Healthy") ?? 0) * 2);

    private static string ResolveStatusArabic(string? status) => status switch
    {
        "Healthy" => "تشغيل مستقر",
        "Degraded" => "متدهور",
        "Unhealthy" => "غير صحي",
        _ => "غير معروف"
    };

    private static string ResolveCheckIcon(string name)
    {
        if (name.Contains("database", StringComparison.OrdinalIgnoreCase))
        {
            return "database";
        }

        if (name.Contains("service", StringComparison.OrdinalIgnoreCase))
        {
            return "splitscreen";
        }

        if (name.Contains("legacy", StringComparison.OrdinalIgnoreCase))
        {
            return "link_off";
        }

        return "deployed_code";
    }

    private static string MapProtocolClass(string? status) => status switch
    {
        "Healthy" => "is-healthy",
        "Degraded" => "is-degraded",
        "Unhealthy" => "is-unhealthy",
        _ => string.Empty
    };

    private static string MapBadgeClass(string? status) => status switch
    {
        "Healthy" => "is-success",
        "Degraded" => "is-warning",
        "Unhealthy" => "is-danger",
        _ => "is-neutral"
    };

    private IEnumerable<ConsoleLine> BuildConsoleLines()
    {
        if (_report is null)
        {
            yield break;
        }

        foreach (var check in _report.Checks.Take(5))
        {
            yield return new ConsoleLine(
                DateTime.Now.AddMilliseconds(-check.Duration).ToString("HH:mm:ss"),
                $"{check.Name} :: {(string.IsNullOrWhiteSpace(check.Description) ? "Internal diagnostic completed." : check.Description)}",
                check.Status == "Unhealthy" ? "ERR" : check.Status == "Degraded" ? "WARN" : "OK",
                check.Status == "Unhealthy" ? "is-error" : check.Status == "Degraded" ? "is-warning" : "is-ok");
        }
    }

    private sealed class HealthReportViewModel
    {
        public string Status { get; set; } = string.Empty;
        public List<HealthCheckEntryViewModel> Checks { get; set; } = [];
        public double TotalDuration { get; set; }
    }

    private sealed class HealthCheckEntryViewModel
    {
        public string Name { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string? Description { get; set; }
        public double Duration { get; set; }
    }

    private sealed record ConsoleLine(string Time, string Text, string Level, string Class);
}
