@page "/admin/health"
@layout MainLayout
@inherits AppPageBase
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@using System.Net.Http.Json
@using Microsoft.Extensions.DependencyInjection

<PageHeader Title='@L["Health"]'
            Breadcrumb='@L["Dashboard"]'
            Subtitle='@L["SystemHealth"]'>
    <Actions>
        <button type="button" class="btn btn-secondary" @onclick="LoadAsync" disabled="@_isLoading">
            @if (_isLoading)
            {
                <LoadingSpinner Size="small" />
            }
            <span>@L["Refresh"]</span>
        </button>
    </Actions>
</PageHeader>

@if (HasError)
{
    <ErrorDisplay Message="@ErrorMessage"
                  ReferenceNumber="@ErrorReferenceNumber"
                  TechnicalDetails="@ErrorTechnicalDetails"
                  ShowTechnicalDetails="true"
                  OnRetry="LoadAsync" />
}
else if (_isLoading)
{
    <div class="health-page__loading card">
        <LoadingSpinner Size="large" />
        <span>@L["Loading"]</span>
    </div>
}
else if (_report is null)
{
    <EmptyState Message='@L["NoResults"]' />
}
else
{
    <div class="health-page">
        <div class="card health-page__summary">
            <div class="health-page__summary-text">
                <div class="text-muted">@L["OverallStatus"]</div>
                <h3>@L["SystemHealth"]</h3>
            </div>
            <Badge Text="@_report.Status" Variant="@MapVariant(_report.Status)" />
        </div>

        <div class="card">
            <div class="table-responsive">
                <table class="table align-middle health-page__table">
                    <thead>
                        <tr>
                            <th>@L["CheckName"]</th>
                            <th>@L["Status"]</th>
                            <th>@L["Duration"] (ms)</th>
                            <th>@L["Description"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var check in _report.Checks)
                        {
                            <tr>
                                <td>@check.Name</td>
                                <td>
                                    <Badge Text="@check.Status" Variant="@MapVariant(check.Status)" />
                                </td>
                                <td>@check.Duration.ToString("0.##")</td>
                                <td>@(string.IsNullOrWhiteSpace(check.Description) ? "-" : check.Description)</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
}

@code {
    private HealthReportViewModel? _report;
    private bool _isLoading = true;

    protected override Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender)
        {
            return Task.CompletedTask;
        }

        return LoadAsync();
    }

    private async Task LoadAsync()
    {
        ClearError();
        _isLoading = true;
        _report = null;
        StateHasChanged();

        try
        {
            var factoryType = Type.GetType("System.Net.Http.IHttpClientFactory, Microsoft.Extensions.Http")
                ?? throw new InvalidOperationException("IHttpClientFactory type is unavailable.");
            var factory = Services.GetService(factoryType)
                ?? throw new InvalidOperationException("IHttpClientFactory is not registered.");
            var createClientMethod = factoryType.GetMethod("CreateClient", [typeof(string)])
                ?? throw new InvalidOperationException("CreateClient method was not found.");
            using var client = (HttpClient?)createClientMethod.Invoke(factory, ["ApiAuthenticated"])
                ?? throw new InvalidOperationException("Authenticated HttpClient could not be created.");
            var result = await client.GetFromJsonAsync<HealthReportViewModel>("api/health");

            if (result is null)
            {
                throw new InvalidOperationException("Health check response was empty.");
            }

            _report = result;
        }
        catch (Exception ex)
        {
            SetError(ex);
            ToastService.ShowError(L["ErrorOccurred"]);
        }
        finally
        {
            _isLoading = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    private static string MapVariant(string? status) => status switch
    {
        "Healthy" => "success",
        "Degraded" => "warning",
        "Unhealthy" => "error",
        _ => "info"
    };

    private sealed class HealthReportViewModel
    {
        public string Status { get; set; } = string.Empty;
        public List<HealthCheckEntryViewModel> Checks { get; set; } = [];
        public double TotalDuration { get; set; }
    }

    private sealed class HealthCheckEntryViewModel
    {
        public string Name { get; set; } = string.Empty;
        public string Status { get; set; } = string.Empty;
        public string? Description { get; set; }
        public double Duration { get; set; }
    }
}
