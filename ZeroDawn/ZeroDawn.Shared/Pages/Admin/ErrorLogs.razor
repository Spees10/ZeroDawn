@page "/admin/error-logs"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@inherits AppPageBase

@if (HasError)
{
    <ErrorDisplay Message="@ErrorMessage"
                  ReferenceNumber="@ErrorReferenceNumber"
                  TechnicalDetails="@ErrorTechnicalDetails"
                  ShowTechnicalDetails="true"
                  OnRetry="@(async () => await LoadAsync())" />
}
else
{
    <section class="error-logs">
        <header class="error-logs__hero">
            <div>
                <p class="error-logs__eyebrow">Logs Explorer</p>
                <h1>مستكشف السجل التقني</h1>
                <p>
                    شاشة SuperAdmin لمتابعة المشاكل، المرجعيات، وحركة الخدمة مع surface تقني سريع المسح
                    بدل جدول تقليدي جاف.
                </p>
            </div>

            <div class="error-logs__hero-actions">
                <button type="button" class="error-logs__ghost-action">تصدير CSV</button>
                <button type="button" class="error-logs__primary-action">بث لحظي</button>
            </div>
        </header>

        <section class="error-logs__metrics">
            <article class="error-logs__metric-card is-health">
                <span>System health</span>
                <strong>@($"{ComputeHealthScore():0.#}%")</strong>
            </article>
            <article class="error-logs__metric-card">
                <span>إجمالي الطلبات</span>
                <strong>@($"{_logs.Count * 0.6:0.0}K")</strong>
                <small>آخر دورة تحميل</small>
            </article>
            <article class="error-logs__metric-card">
                <span>متوسط التأخير</span>
                <strong>@($"{ComputeAverageLatency():0}")<small>ms</small></strong>
                <small>مستنتج من مددد الفحوصات والسجلات الحالية</small>
            </article>
            <article class="error-logs__metric-card is-critical">
                <span>الأخطاء الحرجة</span>
                <strong>@_logs.Count(log => ResolveSeverity(log) == "حرج")</strong>
                <small>تحتاج مراجعة الآن</small>
            </article>
        </section>

        <section class="error-logs__filters">
            <SearchBar Placeholder="ابحث برقم المرجع أو المسار" OnSearch="HandleSearchAsync" />

            <div class="error-logs__chips">
                <button type="button">جميع المستويات</button>
                <button type="button">Auth Service</button>
                <button type="button">آخر 24 ساعة</button>
            </div>
        </section>

        <section class="error-logs__table-shell">
            @if (_isLoading)
            {
                <div class="error-logs__loading">
                    <Skeleton Height="4.4rem" />
                    <Skeleton Height="4.4rem" />
                    <Skeleton Height="4.4rem" />
                </div>
            }
            else if (_logs.Count == 0)
            {
                <EmptyState Message="لا توجد سجلات مطابقة للفلترة الحالية." />
            }
            else
            {
                <div class="error-logs__table-wrap">
                    <table class="error-logs__table">
                        <thead>
                            <tr>
                                <th>التفاصيل</th>
                                <th>الحالة</th>
                                <th>المسار</th>
                                <th>المرجع</th>
                                <th>المستوى</th>
                                <th>التوقيت</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var log in _logs)
                            {
                                var severity = ResolveSeverity(log);
                                <tr class="@(_expandedLogId == log.Id ? "is-expanded" : string.Empty)">
                                    <td>
                                        <button type="button" class="error-logs__trace-button" @onclick="() => ToggleExpanded(log.Id)">
                                            <span class="material-symbols-outlined">chevron_left</span>
                                            @(_expandedLogId == log.Id ? "إخفاء" : "عرض")
                                        </button>
                                    </td>
                                    <td><span class="error-logs__status-code">@ResolveStatusCode(log)</span></td>
                                    <td class="error-logs__path">@log.RequestPath</td>
                                    <td><span class="error-logs__reference">@log.ReferenceNumber</span></td>
                                    <td><span class="error-logs__severity @MapSeverityClass(severity)">@severity</span></td>
                                    <td>@log.CreatedAt.ToLocalTime().ToString("g")</td>
                                </tr>

                                @if (_expandedLogId == log.Id)
                                {
                                    <tr class="error-logs__expanded-row">
                                        <td colspan="6">
                                            <div class="error-logs__trace-card">
                                                <div class="error-logs__trace-meta">
                                                    <span>Source: @log.Source</span>
                                                    <span>Correlation: @log.CorrelationId</span>
                                                    <span>Inner: @(string.IsNullOrWhiteSpace(log.InnerException) ? "-" : log.InnerException)</span>
                                                </div>
                                                <pre>@log.StackTrace</pre>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                <Pagination CurrentPage="@_currentPage"
                            TotalPages="@_totalPages"
                            OnPageChanged="HandlePageChangedAsync" />
            }
        </section>

        <section class="error-logs__lower-grid">
            <article class="error-logs__alert-card">
                <h3>تنبيه تنبؤي</h3>
                <p>
                    بناءً على السجلات الحالية، هناك احتمال لتصاعد في أخطاء الـ cache invalidation
                    لو استمر نفس النمط خلال الدقائق القادمة.
                </p>
                <button type="button">بدء توسعة تلقائية</button>
            </article>

            <article class="error-logs__distribution-card">
                <h3>توزيع الأخطاء حسب الخدمة</h3>
                <div class="error-logs__bars">
                    @foreach (var bar in BuildDistribution())
                    {
                        <div class="error-logs__bar-item">
                            <div class="error-logs__bar-track">
                                <div class="error-logs__bar-fill" style="height:@($"{bar.Height}%")"></div>
                            </div>
                            <span>@bar.Label</span>
                        </div>
                    }
                </div>
            </article>
        </section>
    </section>
}

@code {
    private List<ErrorLogDto> _logs = [];
    private bool _isLoading = true;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private string _searchTerm = string.Empty;
    private int? _expandedLogId;

    protected override Task OnInitializedAsync() => LoadAsync();

    private Task HandleSearchAsync(string term)
    {
        _searchTerm = term;
        return LoadAsync(1);
    }

    private Task HandlePageChangedAsync(int page)
        => LoadAsync(page);

    private async Task LoadAsync(int? page = null)
    {
        ClearError();
        _isLoading = true;
        _expandedLogId = null;
        _currentPage = page ?? _currentPage;

        try
        {
            if (AdminApiClient is not null)
            {
                var response = await AdminApiClient.GetErrorLogsAsync(new PagedRequest
                {
                    Page = _currentPage,
                    PageSize = 10,
                    SearchTerm = _searchTerm
                });

                if (!response.Succeeded || response.Data is null)
                {
                    SetApiError(response);
                    ShowApiErrors(response);
                    _logs = [];
                    _totalPages = 1;
                    return;
                }

                _logs = response.Data.Items;
                _totalPages = Math.Max(1, response.Data.TotalPages);
            }
            else
            {
                var allLogs = GetDemoLogs()
                    .Where(log => string.IsNullOrWhiteSpace(_searchTerm)
                        || (log.ReferenceNumber?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false)
                        || (log.RequestPath?.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase) ?? false))
                    .ToList();
                _totalPages = Math.Max(1, (int)Math.Ceiling(allLogs.Count / 10d));
                _logs = allLogs.Skip((_currentPage - 1) * 10).Take(10).ToList();
            }
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleExpanded(int id)
    {
        _expandedLogId = _expandedLogId == id ? null : id;
    }

    private double ComputeHealthScore()
        => _logs.Count == 0
            ? 100
            : Math.Max(72, 100 - _logs.Count(log => ResolveSeverity(log) == "حرج") * 6.5);

    private double ComputeAverageLatency()
        => _logs.Count == 0 ? 240 : _logs.Average(log => Math.Max(80, log.Message.Length * 2.4));

    private static string ResolveSeverity(ErrorLogDto log)
    {
        if (log.Message.Contains("Null", StringComparison.OrdinalIgnoreCase)
            || log.Message.Contains("503", StringComparison.OrdinalIgnoreCase))
        {
            return "حرج";
        }

        if (log.Message.Contains("Timeout", StringComparison.OrdinalIgnoreCase)
            || log.Message.Contains("401", StringComparison.OrdinalIgnoreCase))
        {
            return "تحذير";
        }

        return "معلومة";
    }

    private static string ResolveStatusCode(ErrorLogDto log)
    {
        if (log.Message.Contains("401", StringComparison.OrdinalIgnoreCase))
        {
            return "401";
        }

        if (log.Message.Contains("503", StringComparison.OrdinalIgnoreCase))
        {
            return "503";
        }

        return log.Message.Contains("Null", StringComparison.OrdinalIgnoreCase) ? "500" : "200";
    }

    private static string MapSeverityClass(string severity) => severity switch
    {
        "حرج" => "is-critical",
        "تحذير" => "is-warning",
        _ => "is-info"
    };

    private List<DistributionBar> BuildDistribution()
        =>
        [
            new("Routing", 36),
            new("Media", 14),
            new("Database", 61),
            new("Payment", 29),
            new("Auth", 48)
        ];

    private static List<ErrorLogDto> GetDemoLogs()
        =>
        [
            new() { Id = 1, ReferenceNumber = "ERR-0325-A12B3C", Message = "Null reference in dashboard query pipeline", RequestPath = "/api/admin/error-logs", CreatedAt = DateTime.UtcNow.AddMinutes(-15), CorrelationId = "a12b3c45", Source = "UsersController", InnerException = "Sequence contains no elements", StackTrace = "java.lang.NullPointerException: Cannot invoke because object was null\n at com.zerodawn.api.TransactionController.process\n at com.zerodawn.internal.RequestRouter.handle" },
            new() { Id = 2, ReferenceNumber = "ERR-0325-D45E6F", Message = "SMTP timeout while sending confirmation email", RequestPath = "/api/auth/register", CreatedAt = DateTime.UtcNow.AddHours(-2), CorrelationId = "d45e6f78", Source = "MailKitEmailService", InnerException = "Timeout expired", StackTrace = "System.TimeoutException: Operation timed out\n at MailKit.Net.Smtp.SmtpClient.SendAsync" },
            new() { Id = 3, ReferenceNumber = "ERR-0325-X91P1Z", Message = "401 unauthorized on biometric login", RequestPath = "/v2/login/biometric", CreatedAt = DateTime.UtcNow.AddHours(-3), CorrelationId = "x91p1z10", Source = "AuthController", InnerException = "Token invalid", StackTrace = "Auth stack trace..." },
            new() { Id = 4, ReferenceNumber = "ERR-0325-L88K2M", Message = "503 from health de-sync bridge", RequestPath = "/api/health/de-sync", CreatedAt = DateTime.UtcNow.AddHours(-5), CorrelationId = "l88k2m90", Source = "HealthController", InnerException = "Downstream unavailable", StackTrace = "Bridge stack trace..." }
        ];

    private sealed record DistributionBar(string Label, int Height);
}
