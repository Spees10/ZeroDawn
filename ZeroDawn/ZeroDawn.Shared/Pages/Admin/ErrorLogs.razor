@page "/admin/error-logs"
@layout MainLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "SuperAdmin")]
@inherits AppPageBase

<PageHeader Title="Error Logs"
            Breadcrumb='@L["Dashboard"]'
            Subtitle="Review recent system errors" />

@if (HasError)
{
    <ErrorDisplay Message="@ErrorMessage"
                  ReferenceNumber="@ErrorReferenceNumber"
                  TechnicalDetails="@ErrorTechnicalDetails"
                  ShowTechnicalDetails="true"
                  OnRetry="@(async () => await LoadAsync())" />
}
else
{
    <div class="card">
        <div class="d-flex justify-content-between align-items-center flex-wrap gap-2 mb-3">
            <SearchBar Placeholder="Search by reference number" OnSearch="HandleSearchAsync" />
            @if (_isLoading)
            {
                <LoadingSpinner Size="small" />
            }
        </div>

        @if (_isLoading)
        {
            <div class="d-flex flex-column gap-2">
                <Skeleton Height="3rem" />
                <Skeleton Height="3rem" />
            </div>
        }
        else if (_logs.Count == 0)
        {
            <EmptyState Message='@L["NoResults"]' />
        }
        else
        {
            <div class="table-responsive">
                <table class="table align-middle">
                    <thead>
                        <tr>
                            <th>Reference</th>
                            <th>Message</th>
                            <th>Path</th>
                            <th>Created</th>
                            <th>@L["Edit"]</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var log in _logs)
                        {
                            <tr>
                                <td><Badge Text="@log.ReferenceNumber" Variant="error" /></td>
                                <td>@Truncate(log.Message, 70)</td>
                                <td>@log.RequestPath</td>
                                <td>@log.CreatedAt.ToLocalTime().ToString("g")</td>
                                <td>
                                    <button type="button" class="btn btn-secondary" @onclick="() => ToggleExpanded(log.Id)">
                                        @(_expandedLogId == log.Id ? "Hide" : "View")
                                    </button>
                                </td>
                            </tr>

                            @if (_expandedLogId == log.Id)
                            {
                                <tr>
                                    <td colspan="5">
                                        <div class="card">
                                            <div><strong>Source:</strong> @log.Source</div>
                                            <div><strong>Correlation:</strong> @log.CorrelationId</div>
                                            <div><strong>Inner:</strong> @log.InnerException</div>
                                            <pre class="mb-0 mt-3">@log.StackTrace</pre>
                                        </div>
                                    </td>
                                </tr>
                            }
                        }
                    </tbody>
                </table>
            </div>

            <Pagination CurrentPage="@_currentPage"
                        TotalPages="@_totalPages"
                        OnPageChanged="HandlePageChangedAsync" />
        }
    </div>
}

@code {
    private List<ErrorLogDto> _logs = [];
    private bool _isLoading = true;
    private int _currentPage = 1;
    private int _totalPages = 1;
    private string _searchTerm = string.Empty;
    private int? _expandedLogId;

    protected override Task OnInitializedAsync() => LoadAsync();

    private Task HandleSearchAsync(string term)
    {
        _searchTerm = term;
        return LoadAsync(1);
    }

    private Task HandlePageChangedAsync(int page)
        => LoadAsync(page);

    private async Task LoadAsync(int? page = null)
    {
        ClearError();
        _isLoading = true;
        _expandedLogId = null;
        _currentPage = page ?? _currentPage;

        try
        {
            if (AdminApiClient is not null)
            {
                var response = await AdminApiClient.GetErrorLogsAsync(new PagedRequest
                {
                    Page = _currentPage,
                    PageSize = 10,
                    SearchTerm = _searchTerm
                });

                if (!response.Succeeded || response.Data is null)
                {
                    SetApiError(response);
                    ShowApiErrors(response);
                    _logs = [];
                    _totalPages = 1;
                    return;
                }

                _logs = response.Data.Items;
                _totalPages = Math.Max(1, response.Data.TotalPages);
            }
            else
            {
                var allLogs = GetDemoLogs()
                    .Where(log => string.IsNullOrWhiteSpace(_searchTerm)
                        || log.ReferenceNumber.Contains(_searchTerm, StringComparison.OrdinalIgnoreCase))
                    .ToList();
                _totalPages = Math.Max(1, (int)Math.Ceiling(allLogs.Count / 10d));
                _logs = allLogs.Skip((_currentPage - 1) * 10).Take(10).ToList();
            }
        }
        catch (Exception ex)
        {
            SetError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }

    private void ToggleExpanded(int id)
    {
        _expandedLogId = _expandedLogId == id ? null : id;
    }

    private static string Truncate(string value, int maxLength)
        => value.Length <= maxLength ? value : $"{value[..maxLength]}...";

    private static List<ErrorLogDto> GetDemoLogs()
        =>
        [
            new() { Id = 1, ReferenceNumber = "ERR-0325-A12B3C", Message = "Null reference in dashboard query pipeline", RequestPath = "/api/admin/error-logs", CreatedAt = DateTime.UtcNow.AddMinutes(-15), CorrelationId = "a12b3c45", Source = "UsersController", InnerException = "Sequence contains no elements", StackTrace = "Sample stack trace..." },
            new() { Id = 2, ReferenceNumber = "ERR-0325-D45E6F", Message = "SMTP timeout while sending confirmation email", RequestPath = "/api/auth/register", CreatedAt = DateTime.UtcNow.AddHours(-2), CorrelationId = "d45e6f78", Source = "MailKitEmailService", InnerException = "Timeout expired", StackTrace = "Sample stack trace..." }
        ];
}
