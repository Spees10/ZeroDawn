@page "/reset-password"
@layout AuthLayout
@inherits AuthPageBase
@using Microsoft.AspNetCore.Components
@using ZeroDawn.Shared.Contracts.Auth

<div class="auth-flow">
    <header class="auth-flow__header">
        <div class="auth-flow__eyebrow">@L["ResetPassword"]</div>
        <h1 class="auth-flow__title">إعادة تعيين كلمة المرور</h1>
        <p class="auth-flow__subtitle">حدّث هويتك الرقمية بكلمة مرور جديدة قوية تضمن استمرار الوصول الآمن إلى مساحة عملك.</p>
    </header>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }

    @if (_invalidLink)
    {
        <div class="auth-state auth-state--error">
            <div class="auth-state__icon">
                <span class="material-symbols-outlined">link_off</span>
            </div>
            <h3 class="auth-state__title">@L["InvalidLink"]</h3>
            <p class="auth-state__copy">الرابط الحالي غير صالح أو انتهت صلاحيته. اطلب رابطًا جديدًا لإكمال العملية.</p>
            <div class="auth-flow__actions mt-4">
                <a class="btn btn-secondary" href="/resend-confirmation">@L["ResendEmail"]</a>
                <a class="btn btn-primary" href="/login">@L["BackToLogin"]</a>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="auth-flow__form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <FormField TValue="string" Label="@L["NewPassword"]" For="() => _model.NewPassword">
                <FormPasswordInput @bind-Value="_model.NewPassword"
                                   placeholder="••••••••••••"
                                   dir="ltr" />
            </FormField>

            <FormField TValue="string" Label="@L["ConfirmPassword"]" For="() => _model.ConfirmPassword">
                <FormPasswordInput @bind-Value="_model.ConfirmPassword"
                                   placeholder="••••••••••••"
                                   dir="ltr" />
            </FormField>

            <div class="auth-requirements">
                <div class="auth-requirements__title">متطلبات الأمان</div>
                <div class="auth-requirements__grid">
                    <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>8 أحرف على الأقل</span></div>
                    <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>رقم واحد على الأقل</span></div>
                    <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>حرف كبير واحد</span></div>
                    <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>حرف صغير واحد</span></div>
                </div>
            </div>

            <SubmitButton Text="Reset Password"
                          LoadingText="@L["ProcessingRequest"]"
                          IsLoading="@_isLoading"
                          IsDisabled="@_isLoading" />
        </EditForm>
    }
</div>

@code {
    private readonly ResetPasswordRequest _model = new();
    private bool _isLoading;
    private bool _invalidLink;

    [SupplyParameterFromQuery(Name = "email")]
    public string? Email { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    protected override void OnParametersSet()
    {
        _model.Email = Email ?? string.Empty;
        _model.Token = Token ?? string.Empty;
        _invalidLink = string.IsNullOrWhiteSpace(_model.Email) || string.IsNullOrWhiteSpace(_model.Token);
    }

    private async Task SubmitAsync()
    {
        if (_isLoading || _invalidLink)
        {
            return;
        }

        ClearUnhandledError();
        _isLoading = true;

        try
        {
            var response = await AuthService.ResetPasswordAsync(_model);
            if (!response.Succeeded)
            {
                ShowApiErrors(response);
                return;
            }

            ShowSuccess(L["ResetPasswordSuccess"], response.Message);
            NavigationManager.NavigateTo("/login");
        }
        catch (Exception ex)
        {
            SetUnhandledError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
