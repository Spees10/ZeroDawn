@page "/resend-confirmation"
@layout AuthLayout
@inherits AuthPageBase
@using ZeroDawn.Shared.Contracts.Auth

<div class="auth-flow">
    <header class="auth-flow__header">
        <div class="auth-flow__eyebrow">@L["ResendEmail"]</div>
        <h1 class="auth-flow__title">إعادة إرسال التأكيد</h1>
        <p class="auth-flow__subtitle">أدخل بريدك الإلكتروني وسنرسل لك رابط تحقق جديد لتفعيل حسابك بسرعة.</p>
    </header>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }

    <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="auth-flow__form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <FormField TValue="string" Label="@L["Email"]" For="() => _model.Email">
            <FormInput @bind-Value="_model.Email"
                       placeholder="name@company.com"
                       dir="ltr" />
        </FormField>

        <SubmitButton Text="إرسال الرابط الآن"
                      LoadingText="@L["SendingEmail"]"
                      IsLoading="@_isLoading"
                      IsDisabled="@_isLoading" />

        <div class="auth-note">
            <div class="auth-note__title">معلومة مهمة</div>
            <p class="auth-note__body">لو لم تصل الرسالة، افحص البريد غير الهام ثم أعد المحاولة بعد دقائق قليلة.</p>
        </div>
    </EditForm>
</div>

@code {
    private readonly ResendConfirmationRequest _model = new();
    private bool _isLoading;

    private async Task SubmitAsync()
    {
        if (_isLoading)
        {
            return;
        }

        ClearUnhandledError();
        _isLoading = true;

        try
        {
            var response = await AuthService.ResendConfirmationAsync(_model);
            if (!response.Succeeded)
            {
                ShowApiErrors(response);
                return;
            }

            ShowSuccess(L["RequestSubmitted"], response.Message ?? L["CheckYourEmailMessage"]);
        }
        catch (Exception ex)
        {
            SetUnhandledError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
