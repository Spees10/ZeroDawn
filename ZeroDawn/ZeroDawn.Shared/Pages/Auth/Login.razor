@page "/login"
@layout AuthLayout
@inherits AuthPageBase
@using ZeroDawn.Shared.Contracts.Auth

<div class="auth-flow">
    <header class="auth-flow__header">
        <div class="auth-flow__eyebrow">@L["SecureAccessPortal"]</div>
        <h1 class="auth-flow__title">@L["Login"]</h1>
        <p class="auth-flow__subtitle">أدخل بيانات الاعتماد الخاصة بك للوصول إلى لوحة التحكم وإدارة النظام بهدوء ووضوح.</p>
    </header>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }

    <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="auth-flow__form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <FormField TValue="string" Label="@L["Email"]" For="() => _model.Email">
            <FormInput @bind-Value="_model.Email"
                       IconContent="@EmailIcon"
                       placeholder="name@company.com"
                       type="email"
                       dir="ltr" />
        </FormField>

        <FormField TValue="string" Label="@L["Password"]" For="() => _model.Password">
            <FormPasswordInput @bind-Value="_model.Password"
                               placeholder="••••••••"
                               dir="ltr" />
        </FormField>

        <div class="auth-flow__links">
            <a class="auth-link" href="/forgot-password">@L["ForgotPassword"]</a>

            @if (AllowSelfRegistration)
            {
                <span class="text-muted">
                    @L["NeedAnAccount"]
                    <a class="auth-footer__link" href="/register">@L["Register"]</a>
                </span>
            }
        </div>

        <SubmitButton Text="الدخول إلى النظام"
                      LoadingText="@L["SigningIn"]"
                      IsLoading="@_isLoading"
                      IsDisabled="@_isLoading" />
    </EditForm>
</div>

@code {
    private readonly LoginRequest _model = new();
    private bool _isLoading;

    private RenderFragment EmailIcon => @<span class="material-symbols-outlined">mail</span>;

    private async Task SubmitAsync()
    {
        if (_isLoading)
        {
            return;
        }

        ClearUnhandledError();
        _isLoading = true;

        try
        {
            var response = await AuthService.LoginAsync(_model);
            if (!response.Succeeded || response.Data is null)
            {
                ShowApiErrors(response);
                return;
            }

            await NotifyAuthStateChangedAsync();
            ShowSuccess(L["Login"], response.Message);
            NavigationManager.NavigateTo("/");
        }
        catch (Exception ex)
        {
            SetUnhandledError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
