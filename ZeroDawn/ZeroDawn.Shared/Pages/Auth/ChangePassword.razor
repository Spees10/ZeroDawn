@page "/change-password"
@layout AuthLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits AuthPageBase
@using ZeroDawn.Shared.Contracts.Auth
@using ZeroDawn.Shared.Layout

<div class="d-flex flex-column gap-4">
    <div>
        <h1 class="mb-2">@L["ChangePassword"]</h1>
        <p class="text-muted mb-0">@L["Profile"]</p>
    </div>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }

    <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="d-flex flex-column gap-4">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <FormField TValue="string" Label="@L["CurrentPassword"]" For="() => _model.CurrentPassword">
            <FormPasswordInput @bind-Value="_model.CurrentPassword"
                               placeholder="@L["CurrentPassword"]" />
        </FormField>

        <FormField TValue="string" Label="@L["NewPassword"]" For="() => _model.NewPassword">
            <FormPasswordInput @bind-Value="_model.NewPassword"
                               placeholder="@L["NewPassword"]" />
        </FormField>

        <FormField TValue="string" Label="@L["ConfirmPassword"]" For="() => _model.ConfirmPassword">
            <FormPasswordInput @bind-Value="_model.ConfirmPassword"
                               placeholder="@L["ConfirmPassword"]" />
        </FormField>

        <SubmitButton Text="@L["ChangePassword"]"
                      LoadingText="@L["ProcessingRequest"]"
                      IsLoading="@_isLoading"
                      IsDisabled="@_isLoading" />
    </EditForm>
</div>

@code {
    private readonly ChangePasswordRequest _model = new();
    private bool _isLoading;

    private async Task SubmitAsync()
    {
        if (_isLoading)
        {
            return;
        }

        ClearUnhandledError();
        _isLoading = true;

        try
        {
            var response = await AuthService.ChangePasswordAsync(_model);
            if (!response.Succeeded)
            {
                ShowApiErrors(response);
                return;
            }

            _model.CurrentPassword = string.Empty;
            _model.NewPassword = string.Empty;
            _model.ConfirmPassword = string.Empty;

            ShowSuccess(L["ChangePasswordSuccess"], response.Message);
        }
        catch (Exception ex)
        {
            SetUnhandledError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
