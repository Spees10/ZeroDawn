@page "/change-password"
@layout AuthLayout
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@inherits AuthPageBase
@using ZeroDawn.Shared.Contracts.Auth

<div class="auth-flow">
    <header class="auth-flow__header">
        <div class="auth-flow__eyebrow">@L["ChangePassword"]</div>
        <h1 class="auth-flow__title">تغيير كلمة المرور</h1>
        <p class="auth-flow__subtitle">حدّث أمان حسابك بانتظام للحفاظ على خصوصية البيانات والوصول الموثوق عبر كل الأجهزة.</p>
    </header>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }

    <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="auth-flow__form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <FormField TValue="string" Label="@L["CurrentPassword"]" For="() => _model.CurrentPassword">
            <FormPasswordInput @bind-Value="_model.CurrentPassword"
                               placeholder="••••••••••••"
                               dir="ltr" />
        </FormField>

        <FormField TValue="string" Label="@L["NewPassword"]" For="() => _model.NewPassword">
            <FormPasswordInput @bind-Value="_model.NewPassword"
                               placeholder="••••••••••••"
                               dir="ltr" />
        </FormField>

        <FormField TValue="string" Label="@L["ConfirmPassword"]" For="() => _model.ConfirmPassword">
            <FormPasswordInput @bind-Value="_model.ConfirmPassword"
                               placeholder="••••••••••••"
                               dir="ltr" />
        </FormField>

        <div class="auth-requirements">
            <div class="auth-requirements__title">متطلبات الأمان</div>
            <div class="auth-requirements__grid">
                <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>12 حرفًا أو أكثر</span></div>
                <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>أرقام وحروف متنوعة</span></div>
                <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>حرف كبير واحد على الأقل</span></div>
                <div class="auth-requirements__item"><span class="material-symbols-outlined">check_circle</span><span>لا تعِد استخدام كلمة قديمة</span></div>
            </div>
        </div>

        <SubmitButton Text="تحديث كلمة المرور"
                      LoadingText="@L["ProcessingRequest"]"
                      IsLoading="@_isLoading"
                      IsDisabled="@_isLoading" />
    </EditForm>
</div>

@code {
    private readonly ChangePasswordRequest _model = new();
    private bool _isLoading;

    private async Task SubmitAsync()
    {
        if (_isLoading)
        {
            return;
        }

        ClearUnhandledError();
        _isLoading = true;

        try
        {
            var response = await AuthService.ChangePasswordAsync(_model);
            if (!response.Succeeded)
            {
                ShowApiErrors(response);
                return;
            }

            _model.CurrentPassword = string.Empty;
            _model.NewPassword = string.Empty;
            _model.ConfirmPassword = string.Empty;

            ShowSuccess(L["ChangePasswordSuccess"], response.Message);
        }
        catch (Exception ex)
        {
            SetUnhandledError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
