@page "/forgot-password"
@layout AuthLayout
@inherits AuthPageBase
@using ZeroDawn.Shared.Contracts.Auth

<div class="auth-flow">
    <header class="auth-flow__header">
        <div class="auth-flow__eyebrow">@L["ForgotPassword"]</div>
        <h1 class="auth-flow__title">نسيت كلمة المرور؟</h1>
        <p class="auth-flow__subtitle">أدخل بريدك الإلكتروني المسجل وسنرسل لك رابطًا آمنًا لاستعادة الوصول إلى حسابك.</p>
    </header>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="auth-state auth-state--success">
            <div class="auth-state__icon">
                <span class="material-symbols-outlined">outgoing_mail</span>
            </div>
            <h3 class="auth-state__title">@L["RequestSubmitted"]</h3>
            <p class="auth-state__copy">@_successMessage</p>
            <div class="auth-flow__actions mt-4">
                <a class="btn btn-secondary" href="/login">@L["BackToLogin"]</a>
            </div>
        </div>
    }

    <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="auth-flow__form">
        <DataAnnotationsValidator />
        <ValidationSummary />

        <FormField TValue="string" Label="@L["Email"]" For="() => _model.Email">
            <FormInput @bind-Value="_model.Email"
                       placeholder="name@company.com"
                       dir="ltr" />
        </FormField>

        <SubmitButton Text="إرسال رابط الاستعادة"
                      LoadingText="@L["SendingEmail"]"
                      IsLoading="@_isLoading"
                      IsDisabled="@_isLoading" />

        <div class="auth-note">
            <div class="auth-note__title">إشارة أمان</div>
            <p class="auth-note__body">كل طلبات استعادة الحساب تمر عبر قناة مشفرة ولا نكشف ما إذا كان البريد موجودًا أم لا.</p>
        </div>
    </EditForm>
</div>

@code {
    private readonly ForgotPasswordRequest _model = new();
    private bool _isLoading;
    private string? _successMessage;

    private async Task SubmitAsync()
    {
        if (_isLoading)
        {
            return;
        }

        ClearUnhandledError();
        _isLoading = true;

        try
        {
            var response = await AuthService.ForgotPasswordAsync(_model);
            if (!response.Succeeded)
            {
                ShowApiErrors(response);
                return;
            }

            _successMessage = string.IsNullOrWhiteSpace(response.Message)
                ? L["CheckYourEmailMessage"]
                : response.Message;

            ShowSuccess(L["RequestSubmitted"], _successMessage);
        }
        catch (Exception ex)
        {
            SetUnhandledError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
