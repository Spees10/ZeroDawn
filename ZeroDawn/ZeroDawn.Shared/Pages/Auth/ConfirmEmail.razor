@page "/confirm-email"
@layout AuthLayout
@inherits AuthPageBase
@using Microsoft.AspNetCore.Components
@using ZeroDawn.Shared.Contracts.Auth

<div class="auth-flow">
    <header class="auth-flow__header">
        <div class="auth-flow__eyebrow">@L["ConfirmEmail"]</div>
        <h1 class="auth-flow__title">التحقق من البريد الإلكتروني</h1>
        <p class="auth-flow__subtitle">نقوم الآن بمعالجة طلب التحقق وتأمين حسابك قبل نقلك إلى الخطوة التالية.</p>
    </header>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }
    else if (_invalidLink)
    {
        <div class="auth-state auth-state--error">
            <div class="auth-state__icon">
                <span class="material-symbols-outlined">link_off</span>
            </div>
            <h3 class="auth-state__title">@L["InvalidLink"]</h3>
            <p class="auth-state__copy">الرابط غير مكتمل أو انتهت صلاحيته. اطلب رابط تحقق جديد للمتابعة.</p>
            <div class="auth-flow__actions mt-4">
                <a class="btn btn-secondary" href="/resend-confirmation">@L["ResendEmail"]</a>
                <a class="btn btn-primary" href="/login">@L["BackToLogin"]</a>
            </div>
        </div>
    }
    else if (_isSubmitting)
    {
        <div class="auth-state">
            <div class="auth-state__icon">
                <LoadingSpinner Size="large" />
            </div>
            <h3 class="auth-state__title">@L["ConfirmingEmail"]</h3>
            <p class="auth-state__copy">جاري تأكيد الرابط والتحقق من صلاحية الطلب الآن.</p>
        </div>
    }
    else
    {
        <div class="auth-state @(_isSuccess ? "auth-state--success" : "auth-state--error")">
            <div class="auth-state__icon">
                <span class="material-symbols-outlined">@(_isSuccess ? "verified" : "error")</span>
            </div>
            <h3 class="auth-state__title">@(_isSuccess ? L["EmailConfirmedSuccess"] : L["EmailConfirmationFailed"])</h3>
            <p class="auth-state__copy">@_statusMessage</p>
            <div class="auth-flow__actions mt-4">
                @if (!_isSuccess)
                {
                    <button type="button" class="btn btn-secondary" @onclick="SubmitAsync">@L["Retry"]</button>
                }

                <a class="btn btn-primary" href="/login">@L["BackToLogin"]</a>
            </div>
        </div>
    }
</div>

@code {
    private bool _submitted;
    private bool _isSubmitting;
    private bool _invalidLink;
    private bool _isSuccess;
    private string _statusMessage = string.Empty;

    [SupplyParameterFromQuery(Name = "userId")]
    public string? UserId { get; set; }

    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        _invalidLink = string.IsNullOrWhiteSpace(UserId) || string.IsNullOrWhiteSpace(Token);

        if (_submitted || _invalidLink)
        {
            return;
        }

        _submitted = true;
        await SubmitAsync();
    }

    private async Task SubmitAsync()
    {
        if (_isSubmitting || _invalidLink)
        {
            return;
        }

        ClearUnhandledError();
        _isSubmitting = true;

        try
        {
            var response = await AuthService.ConfirmEmailAsync(new ConfirmEmailRequest
            {
                UserId = UserId ?? string.Empty,
                Token = Token ?? string.Empty
            });

            _isSuccess = response.Succeeded;
            _statusMessage = response.Succeeded
                ? (string.IsNullOrWhiteSpace(response.Message) ? L["EmailConfirmedSuccess"] : response.Message!)
                : (!string.IsNullOrWhiteSpace(response.Error) ? response.Error! : L["EmailConfirmationFailed"]);

            if (!response.Succeeded)
            {
                ShowApiErrors(response);
            }
            else
            {
                ShowSuccess(L["EmailConfirmedSuccess"], _statusMessage);
            }
        }
        catch (Exception ex)
        {
            _isSuccess = false;
            _statusMessage = L["EmailConfirmationFailed"];
            SetUnhandledError(ex);
        }
        finally
        {
            _isSubmitting = false;
        }
    }
}
