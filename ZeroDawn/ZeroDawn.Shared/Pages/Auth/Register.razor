@page "/register"
@layout AuthLayout
@inherits AuthPageBase
@using ZeroDawn.Shared.Contracts.Auth

<div class="auth-flow">
    <header class="auth-flow__header">
        <div class="auth-flow__eyebrow">ZeroDawn Premium</div>
        <h1 class="auth-flow__title">إنشاء حساب جديد</h1>
        <p class="auth-flow__subtitle">انضم إلى مساحة العمل الآمنة وابدأ إدارة حسابك ضمن نفس اللغة البصرية الهادئة للنظام.</p>
    </header>

    @if (HasUnhandledError)
    {
        <ErrorDisplay Message="@ErrorMessage"
                      ReferenceNumber="@ErrorReferenceNumber"
                      TechnicalDetails="@ErrorTechnicalDetails"
                      ShowTechnicalDetails="true"
                      OnRetry="SubmitAsync" />
    }

    @if (!string.IsNullOrWhiteSpace(_successMessage))
    {
        <div class="auth-state auth-state--success">
            <div class="auth-state__icon">
                <span class="material-symbols-outlined">mark_email_read</span>
            </div>
            <h3 class="auth-state__title">@L["CheckYourEmail"]</h3>
            <p class="auth-state__copy">@_successMessage</p>
            <div class="auth-flow__actions mt-4">
                <a class="btn btn-primary" href="/login">@L["BackToLogin"]</a>
            </div>
        </div>
    }
    else
    {
        <EditForm Model="_model" OnValidSubmit="SubmitAsync" class="auth-flow__form">
            <DataAnnotationsValidator />
            <ValidationSummary />

            <FormField TValue="string" Label="@L["FullName"]" For="() => _model.FullName">
                <FormInput @bind-Value="_model.FullName"
                           placeholder="أدخل اسمك الكامل" />
            </FormField>

            <FormField TValue="string" Label="@L["Email"]" For="() => _model.Email">
                <FormInput @bind-Value="_model.Email"
                           placeholder="name@company.com"
                           dir="ltr" />
            </FormField>

            <div class="auth-flow__grid">
                <FormField TValue="string" Label="@L["Password"]" For="() => _model.Password">
                    <FormPasswordInput @bind-Value="_model.Password"
                                       placeholder="••••••••"
                                       dir="ltr" />
                </FormField>

                <FormField TValue="string" Label="@L["ConfirmPassword"]" For="() => _model.ConfirmPassword">
                    <FormPasswordInput @bind-Value="_model.ConfirmPassword"
                                       placeholder="••••••••"
                                       dir="ltr" />
                </FormField>
            </div>

            <div class="auth-note">
                <div class="auth-note__title">اتفاق الاستخدام</div>
                <p class="auth-note__body">بإنشاء الحساب فأنت توافق على شروط الخدمة وسياسة الخصوصية الخاصة بـ ZeroDawn.</p>
            </div>

            <SubmitButton Text="إنشاء الحساب"
                          LoadingText="@L["CreatingAccount"]"
                          IsLoading="@_isLoading"
                          IsDisabled="@_isLoading" />

            <div class="auth-flow__footer">
                @L["AlreadyHaveAccount"]
                <a class="auth-footer__link" href="/login">@L["Login"]</a>
            </div>
        </EditForm>
    }
</div>

@code {
    private readonly RegisterRequest _model = new();
    private bool _isLoading;
    private string? _successMessage;

    private async Task SubmitAsync()
    {
        if (_isLoading)
        {
            return;
        }

        ClearUnhandledError();
        _isLoading = true;

        try
        {
            var response = await AuthService.RegisterAsync(_model);
            if (!response.Succeeded)
            {
                ShowApiErrors(response);
                return;
            }

            if (response.Data is not null)
            {
                await NotifyAuthStateChangedAsync();
                ShowSuccess(L["Register"], response.Message);
                NavigationManager.NavigateTo("/");
                return;
            }

            _successMessage = string.IsNullOrWhiteSpace(response.Message)
                ? L["CheckYourEmailMessage"]
                : response.Message;

            ShowSuccess(L["CheckYourEmail"], _successMessage);
        }
        catch (Exception ex)
        {
            SetUnhandledError(ex);
        }
        finally
        {
            _isLoading = false;
        }
    }
}
