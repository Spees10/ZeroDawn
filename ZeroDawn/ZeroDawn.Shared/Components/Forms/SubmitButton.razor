@inject IStringLocalizer<SharedResources> L

<button type="@ButtonType"
        class="submit-button btn btn-primary"
        disabled="@(IsDisabled || IsLoading)"
        @attributes="AdditionalAttributes">
    @if (IsLoading)
    {
        <LoadingSpinner Size="small" />
        <span>@ResolvedLoadingText</span>
    }
    else
    {
        <span>@ResolvedText</span>
    }
</button>

@code {
    [Parameter] public string Text { get; set; } = string.Empty;
    [Parameter] public string LoadingText { get; set; } = string.Empty;
    [Parameter] public bool IsLoading { get; set; }
    [Parameter] public bool IsDisabled { get; set; }
    [Parameter] public string ButtonType { get; set; } = "submit";
    [Parameter(CaptureUnmatchedValues = true)] public IReadOnlyDictionary<string, object>? AdditionalAttributes { get; set; }

    private string ResolvedText => string.IsNullOrWhiteSpace(Text) ? L["Submit"] : Text;
    private string ResolvedLoadingText => string.IsNullOrWhiteSpace(LoadingText) ? L["ProcessingRequest"] : LoadingText;
}
