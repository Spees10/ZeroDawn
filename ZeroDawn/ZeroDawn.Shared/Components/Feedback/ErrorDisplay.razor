@namespace ZeroDawn.Shared.Components.Feedback
@using System.Diagnostics
@using Microsoft.AspNetCore.Components.Authorization
@using Microsoft.Extensions.DependencyInjection
@inject IServiceProvider Services
@inject IStringLocalizer<SharedResources> L

<section class="error-display" role="alert" aria-live="assertive">
    <div class="error-display__visual">
        <span class="material-symbols-outlined">warning</span>
    </div>

    <div class="error-display__content">
        <div class="error-display__header">
            <div>
                <p class="error-display__eyebrow">@L["SomethingWentWrong"]</p>
                <h3>@DisplayMessage</h3>
            </div>

            @if (!string.IsNullOrWhiteSpace(ReferenceNumber))
            {
                <span class="error-display__reference">@L["ReferenceNumber"]: @ReferenceNumber</span>
            }
        </div>

        <p class="error-display__support">
            @if (!string.IsNullOrWhiteSpace(ReferenceNumber))
            {
                @($"{L["ContactSupport"]} {ReferenceNumber}")
            }
            else
            {
                @L["UnexpectedErrorOccurred"]
            }
        </p>

        <div class="error-display__actions">
            @if (OnRetry.HasDelegate)
            {
                <button class="error-display__retry" type="button" @onclick="HandleRetry">@L["TryAgain"]</button>
            }

            @if (ShouldShowTechnicalDetails)
            {
                <button class="error-display__toggle" type="button" @onclick="ToggleDetails">
                    @(detailsVisible ? L["HideTechnicalDetails"] : L["ShowTechnicalDetails"])
                </button>
            }
        </div>

        @if (ShouldShowTechnicalDetails && detailsVisible)
        {
            <div class="error-display__technical">
                <div class="error-display__technical-header">
                    <strong>Debug</strong>
                    <button class="error-display__copy" type="button" @onclick="ShowCopyHint">@L["CopyDetails"]</button>
                </div>

                @if (copyHintVisible)
                {
                    <p class="error-display__hint">@L["CopyDetailsHint"]</p>
                }

                <pre>@TechnicalDetails</pre>
            </div>
        }
    </div>
</section>

@code {
    [Parameter] public string? Message { get; set; }
    [Parameter] public string? ReferenceNumber { get; set; }
    [Parameter] public string? TechnicalDetails { get; set; }
    [Parameter] public bool ShowTechnicalDetails { get; set; }
    [Parameter] public EventCallback OnRetry { get; set; }

    private bool detailsVisible;
    private bool copyHintVisible;
    private bool isPrivilegedViewer;

    private string DisplayMessage
        => string.IsNullOrWhiteSpace(Message)
            ? L["UnexpectedErrorOccurred"]
            : Message;

    private bool ShouldShowTechnicalDetails
        => ShowTechnicalDetails && !string.IsNullOrWhiteSpace(TechnicalDetails) && isPrivilegedViewer;

    protected override async Task OnInitializedAsync()
    {
        isPrivilegedViewer = IsDebugBuild();

        var authenticationStateProvider = Services.GetService<AuthenticationStateProvider>();
        if (authenticationStateProvider is null)
        {
            return;
        }

        try
        {
            var state = await authenticationStateProvider.GetAuthenticationStateAsync();
            isPrivilegedViewer = isPrivilegedViewer || state.User.IsInRole("SuperAdmin");
        }
        catch
        {
        }
    }

    private void ToggleDetails()
    {
        detailsVisible = !detailsVisible;
        if (!detailsVisible)
        {
            copyHintVisible = false;
        }
    }

    private void ShowCopyHint()
    {
        copyHintVisible = true;
    }

    private Task HandleRetry()
        => OnRetry.InvokeAsync();

    private static bool IsDebugBuild()
    {
#if DEBUG
        return true;
#else
        return Debugger.IsAttached;
#endif
    }
}
