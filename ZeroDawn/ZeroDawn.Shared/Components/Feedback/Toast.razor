@implements IDisposable
@namespace ZeroDawn.Shared.Components.Feedback
@inject IStringLocalizer<SharedResources> L

<div class="toast @TypeClass" role="status" aria-live="polite">
    <div class="toast__icon">
        <span class="material-symbols-outlined">@Icon</span>
    </div>
    <div class="toast__body">
        <div class="toast__title">@Title</div>
        <div class="toast__message">@Message</div>
    </div>
    <button class="toast__close" type="button" @onclick="CloseAsync" aria-label="@L["Close"]">
        <span class="material-symbols-outlined">close</span>
    </button>
</div>

@code {
    [Parameter] public string Message { get; set; } = "";
    [Parameter] public ToastType Type { get; set; } = ToastType.Info;
    [Parameter] public int DurationMs { get; set; } = 4000;
    [Parameter] public EventCallback OnClose { get; set; }

    private Timer? dismissTimer;
    private bool closed;

    private string Title => Type switch
    {
        ToastType.Success => L["Success"],
        ToastType.Warning => L["Warning"],
        ToastType.Error => L["Error"],
        _ => L["Info"]
    };

    private string Icon => Type switch
    {
        ToastType.Success => "check_circle",
        ToastType.Warning => "warning",
        ToastType.Error => "error",
        _ => "info"
    };

    private string TypeClass => Type.ToString().ToLowerInvariant();

    protected override void OnParametersSet()
    {
        ResetTimer();
    }

    private void ResetTimer()
    {
        dismissTimer?.Dispose();
        closed = false;

        if (DurationMs <= 0)
        {
            return;
        }

        dismissTimer = new Timer(async _ => await InvokeAsync(CloseAsync), null, DurationMs, Timeout.Infinite);
    }

    private async Task CloseAsync()
    {
        if (closed)
        {
            return;
        }

        closed = true;
        dismissTimer?.Dispose();
        dismissTimer = null;

        if (OnClose.HasDelegate)
        {
            await OnClose.InvokeAsync();
        }
    }

    public void Dispose()
    {
        dismissTimer?.Dispose();
    }
}
