@inject IStringLocalizer<SharedResources> L

<div class="empty-state">
    <div class="empty-state__icon">
        <span class="material-symbols-outlined">@ResolvedIcon</span>
    </div>
    <div class="empty-state__message">@ResolvedMessage</div>

    @if (!string.IsNullOrWhiteSpace(ActionText))
    {
        <button type="button" class="empty-state__action" @onclick="OnAction">
            @ActionText
        </button>
    }
</div>

@code {
    [Parameter] public string Icon { get; set; } = "search_off";
    [Parameter] public string Message { get; set; } = string.Empty;
    [Parameter] public string? ActionText { get; set; }
    [Parameter] public EventCallback OnAction { get; set; }

    private string ResolvedMessage => string.IsNullOrWhiteSpace(Message) ? L["NoResults"] : Message;
    private string ResolvedIcon => string.IsNullOrWhiteSpace(Icon) ? "search_off" : Icon;
}
