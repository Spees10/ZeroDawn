@implements IAsyncDisposable
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<SharedResources> L

<button type="button"
        class="theme-toggle"
        @onclick="ToggleThemeAsync"
        aria-label="@AriaLabel"
        title="@AriaLabel">
    <span class="theme-toggle__icon material-symbols-outlined" aria-hidden="true">@(_isDarkTheme ? "light_mode" : "dark_mode")</span>
    <span class="theme-toggle__text">@(_isDarkTheme ? L["LightTheme"] : L["DarkTheme"])</span>
    <span class="theme-toggle__sr-only">@L["ToggleTheme"]</span>
</button>

@code {
    private IJSObjectReference? _module;
    private bool _isDarkTheme;
    private bool _disposed;

    private string AriaLabel => _isDarkTheme ? L["SwitchToLightTheme"] : L["SwitchToDarkTheme"];

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _disposed)
        {
            return;
        }

        try
        {
            var module = await JSRuntime.InvokeAsync<IJSObjectReference>("import", "./_content/ZeroDawn.Shared/themeToggle.js");

            if (_disposed)
            {
                await module.DisposeAsync();
                return;
            }

            _module = module;

            var currentTheme = await _module.InvokeAsync<string>("getTheme");
            if (currentTheme is "dark" or "light")
            {
                _isDarkTheme = currentTheme == "dark";
                await _module.InvokeVoidAsync("setTheme", currentTheme);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    private async Task ToggleThemeAsync()
    {
        _isDarkTheme = !_isDarkTheme;

        if (_module is null || _disposed)
        {
            return;
        }

        try
        {
            await _module.InvokeVoidAsync("setTheme", _isDarkTheme ? "dark" : "light");
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
        catch (ObjectDisposedException)
        {
        }
    }

    public async ValueTask DisposeAsync()
    {
        _disposed = true;

        if (_module is null)
        {
            return;
        }

        try
        {
            await _module.DisposeAsync();
        }
        catch (JSDisconnectedException)
        {
        }
        catch (JSException)
        {
        }
        catch (ObjectDisposedException)
        {
        }

        _module = null;
    }
}
