@page "/Error"
@using System.Diagnostics

<PageTitle>خطأ</PageTitle>

<h1 class="text-danger">خطأ</h1>
<h2 class="text-danger">حدث خطأ أثناء معالجة الطلب.</h2>

@if (ShowRequestId)
{
    <p>
        <strong>رقم الطلب:</strong> <code>@RequestId</code>
    </p>
}

<h3>وضع التطوير</h3>
<p>
    تفعيل بيئة <strong>Development</strong> سيعرض تفاصيل أكثر عن الخطأ الذي حدث.
</p>
<p>
    <strong>لا يجب تفعيل بيئة Development على التطبيقات المنشورة.</strong>
    قد يؤدي ذلك إلى عرض معلومات حساسة للمستخدمين النهائيين.
    للتشخيص المحلي، فعّل متغير البيئة <strong>ASPNETCORE_ENVIRONMENT</strong> بقيمة <strong>Development</strong>
    ثم أعد تشغيل التطبيق.
</p>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
